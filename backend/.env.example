# ============================================
# VAS FM Online - Backend Environment Variables
# DigitalOcean App Platform Configuration
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3000

# Admin Dashboard Password
# ⚠️ CHANGE THIS to a strong password before deploying!
ADMIN_PASSWORD=YourSecurePassword123!

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================

# Step 1: Go to DigitalOcean App Platform
# URL: https://cloud.digitalocean.com/apps

# Step 2: Create New App
# - Click "Create App"
# - Connect your GitHub repository
# - Repository: gr3enink-stack/ghana-radio-app
# - Branch: main
# - Source Directory: backend
# - Click "Next"

# Step 3: Configure Environment Variables
# In the "Environment Variables" section, add:

# Variable Name          | Value                        | Scope
# ---------------------- | ---------------------------- | -------
# NODE_ENV               | production                   | Run Time
# PORT                   | 3000                         | Run Time  
# ADMIN_PASSWORD         | YourSecurePassword123!       | Run Time (Encrypt ✅)

# ⚠️ IMPORTANT: 
# - Click "Encrypt" for ADMIN_PASSWORD to store it securely
# - Replace "YourSecurePassword123!" with your actual password
# - Use a strong password (min 12 characters, mix of letters, numbers, symbols)

# Step 4: Configure Build Settings
# - Build Command: npm install
# - Run Command: npm start
# - (These should auto-detect from package.json)

# Step 5: Deploy
# - Click "Create Resources"
# - Wait for deployment to complete (~2-3 minutes)
# - Your app will be available at: https://your-app-name.ondigitalocean.app

# ============================================
# ACCESS YOUR DEPLOYED APP
# ============================================

# Admin Dashboard:
# https://your-app-name.ondigitalocean.app

# API Endpoint:
# https://your-app-name.ondigitalocean.app/api/config

# Privacy Policy:
# https://your-app-name.ondigitalocean.app/privacy

# Terms of Service:
# https://your-app-name.ondigitalocean.app/terms

# Admin Login:
# Use the ADMIN_PASSWORD you set above

# ============================================
# UPDATE FLUTTER APP API URL
# ============================================

# After deployment, update these files with your DigitalOcean URL:

# 1. flutter_app/lib/screens/splash_screen.dart
#    Line ~95: Change 'http://172.20.10.3:3000' 
#    to 'https://your-app-name.ondigitalocean.app'

# 2. flutter_app/lib/screens/now_playing_screen.dart  
#    Line ~180: Change 'http://172.20.10.3:3000'
#    to 'https://your-app-name.ondigitalocean.app'

# 3. flutter_app/lib/providers/radio_provider.dart
#    Line ~100: Change 'http://172.20.10.3:3000'
#    to 'https://your-app-name.ondigitalocean.app'

# Then rebuild and redeploy your Flutter app!

# ============================================
# SECURITY CHECKLIST
# ============================================

# ✅ Change ADMIN_PASSWORD to a strong, unique password
# ✅ Enable "Encrypt" for ADMIN_PASSWORD in DigitalOcean
# ✅ Use HTTPS (automatic on DigitalOcean)
# ✅ Don't commit .env files to Git
# ✅ Regularly update your admin password
# ✅ Monitor DigitalOcean logs for suspicious activity

# ============================================
# TROUBLESHOOTING
# ============================================

# If admin dashboard doesn't load:
# - Check DigitalOcean logs
# - Verify Source Directory is set to "backend"
# - Ensure PORT is set to 3000

# If login fails:
# - Verify ADMIN_PASSWORD matches what you're entering
# - Check for typos in the password
# - Password is case-sensitive

# If API returns errors:
# - Check that config.json exists in backend/
# - Verify CORS is enabled (it is by default)
# - Check DigitalOcean logs for error details

# ============================================
# EXAMPLE: STRONG PASSWORD GENERATOR
# ============================================

# Use a password manager or generate one:
# - 16+ characters
# - Mix of uppercase, lowercase, numbers, symbols
# - Example: V@SFm2026!R@d1o#Secure

# ============================================
# DIGITALOCAN TIER RECOMMENDATION
# ============================================

# Basic ($5/month) - Perfect for this app:
# - 512 MB RAM
# - 1 vCPU
# - Sufficient for radio streaming backend

# Professional ($12/month) - If you expect high traffic:
# - 1 GB RAM  
# - Better performance
# - More concurrent connections

# ============================================
# MONITORING & LOGS
# ============================================

# View logs in DigitalOcean:
# 1. Go to your App
# 2. Click "Insights" tab
# 3. View real-time logs
# 4. Monitor CPU, Memory, and Request metrics

# Common log commands:
# - Check deployment logs
# - Monitor error logs
# - Track API requests

# ============================================
# BACKUP & RESTORE
# ============================================

# Your config.json is stored on the DigitalOcean server.
# To backup:
# 1. Login to admin dashboard
# 2. Note your current stream configuration
# 3. Save it locally

# To restore:
# 1. Login to admin dashboard
# 2. Re-enter your stream configuration
# 3. Save

# ============================================
# CUSTOM DOMAIN (OPTIONAL)
# ============================================

# To add a custom domain (e.g., api.mediavas.com):
# 1. Go to your DigitalOcean App
# 2. Click "Settings" tab
# 3. Scroll to "Domains"
# 4. Add your domain
# 5. Update DNS records at your domain registrar
# 6. DigitalOcean will provision SSL certificate automatically

# ============================================
# COST ESTIMATE
# ============================================

# DigitalOcean App Platform (Basic):
# - Backend: $5/month
# - Bandwidth: Included (generous limits)
# - SSL Certificate: Free
# - Total: ~$5/month

# This is perfect for a radio streaming backend!
